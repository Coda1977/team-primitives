# Copy this file to .env.local and fill in the values.
#
# VITE_CONVEX_URL is set automatically by `npx convex dev` on first run.
# It will look like: https://your-deployment.convex.cloud
#
# ANTHROPIC_API_KEY is set on the Convex side (not the client):
#   npx convex env set ANTHROPIC_API_KEY sk-ant-...
#
# OWNER_KEY (Phase G) is set on the Convex side:
#   npx convex env set OWNER_KEY $(openssl rand -hex 16)

VITE_CONVEX_URL=
